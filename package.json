{
  "name": "file_based_task_manager",
  "version": "1.0.0",
  "description": "File-based task manager — Node.js capstone",
  "main": "src/httpServer.js",
  "scripts": {
    "start": "node src/httpServer.js",
    "dev": "nodemon src/httpServer.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "data",
      "logs"
    ]
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
